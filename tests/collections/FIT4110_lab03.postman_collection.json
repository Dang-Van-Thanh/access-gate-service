    {
      "name": "05_Consumer_side_Smoke",
      "item": [
        {
          "name": "POST /access/check - Gọi Core Business để kiểm tra quyền",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cardId\": \"{{cardId}}\",\n  \"gateId\": \"{{gateId}}\",\n  \"direction\": \"IN\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{coreBusinessUrl}}/access/check",
              "host": ["{{coreBusinessUrl}}"],
              "path": ["access", "check"]
            },
            "description": "Smoke test gọi Core Business (chỉ chạy khi có service thật)."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const env = pm.environment.get('env') || 'mock';",
                  "if (env === 'mock') {",
                  "  pm.test('Skipped on mock: Core Business chưa có thật, test chỉ có giá trị trên môi trường local/production', () => {",
                  "    pm.expect(true).to.eql(true);",
                  "  });",
                  "} else {",
                  "  pm.test('Status code 200 từ Core Business', () => {",
                  "    pm.response.to.have.status(200);",
                  "  });",
                  "  pm.test('Response chứa trường allowed (boolean)', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('allowed');",
                  "    pm.expect(json.allowed).to.be.a('boolean');",
                  "  });",
                  "  pm.test('Nếu có message thì không null', () => {",
                  "    const json = pm.response.json();",
                  "    if (json.message !== undefined) {",
                  "      pm.expect(json.message).to.be.a('string');",
                  "    }",
                  "  });",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
