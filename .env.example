# API configuration
APP_HOST=0.0.0.0
APP_PORT=8000
AUTH_TOKEN=local-dev-token
SERVICE_NAME=access-gate
SERVICE_VERSION=0.5.0
ENV=local

# .env.example - copy thành .env và điền giá trị thật
MQTT_HOST=...
MQTT_PORT=...
MQTT_USERNAME=...
MQTT_PASSWORD=...

# URL của Core Business service (ví dụ: http://172.20.10.5:8000)
CORE_SERVICE_URL=http://localhost:8001
# Token để xác thực với Core Business service
AUTH_TOKEN=... 
# Timeout gọi Core (giây)
CORE_REQUEST_TIMEOUT=3.0

# Input/Output topics
INPUT_TOPIC=smart-campus/raw/access/rfid-uid
OUTPUT_TOPIC=smart-campus/events/access

# CSV file path
WHITELIST_CSV=uid_whitelist.csv

# Log level
LOG_LEVEL=INFO