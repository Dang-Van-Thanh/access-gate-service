  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const prefix = pm.environment.get('tracePrefix') || 'access-gate';",
          "pm.variables.set('traceId', prefix + '-' + Date.now());",
          "pm.request.headers.upsert({ key: 'X-Trace-Id', value: pm.variables.get('traceId') });",
          "",
          "// Đảm bảo accessToken có giá trị mặc định nếu chưa set",
          "if (!pm.environment.get('accessToken') && !pm.collectionVariables?.get('accessToken')) {",
          "    const defaultToken = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiJzZXJ2aWNlLWNvcmUiLCJyb2xlIjoiQ09SRV9CVVNJTkVTUyJ9.fakeSignature';",
          "    pm.environment.set('accessToken', defaultToken);",
          "}",
          "",
          "// Set mặc định env = mock nếu chưa có",
          "if (!pm.environment.get('env')) {",
          "    pm.environment.set('env', 'mock');",
          "}"
        ]
      }
    }
  ],
