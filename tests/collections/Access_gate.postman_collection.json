                  "    pm.expect(json).to.have.property('holderName');",
                  "    pm.expect(json).to.have.property('holderRole');",
                  "    pm.expect(json).to.have.property('readerModel');",
                  "  });",
                  "} else {",
                  "  pm.test('404 response has detail', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('detail');",
                  "  });",
                  "}"
