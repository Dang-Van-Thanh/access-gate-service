    {
      "name": "01_Functional",
      "item": [
        {
          "name": "GET /access/logs/recent - Lấy danh sách log mặc định",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/access/logs/recent",
              "host": ["{{baseUrl}}"],
              "path": ["access", "logs", "recent"]
            },
            "description": "Trả về danh sách log phân trang."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response có cấu trúc AccessLogPage', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('items');",
                  "  pm.expect(json).to.have.property('nextCursor');",
                  "  pm.expect(json).to.have.property('hasMore');",
                  "  pm.expect(json.items).to.be.an('array');",
                  "});",
                  "pm.test('Mỗi item nên có các trường cơ bản (không bắt buộc tất cả)', () => {",
                  "  const json = pm.response.json();",
                  "  if (json.items.length > 0) {",
                  "    const item = json.items[0];",
                  "    const expectedFields = ['logId', 'cardId', 'gateId', 'direction', 'timestamp', 'status'];",
                  "    const missingFields = expectedFields.filter(f => !(f in item));",
                  "    if (missingFields.length > 0) {",
                  "      console.warn(`⚠️ Thiếu các field: ${missingFields.join(', ')} trong item đầu tiên. Response thực tế: ${JSON.stringify(item)}`);",
                  "    }",
                  "    // Kiểm tra kiểu dữ liệu nếu field tồn tại",
                  "    if (item.logId) pm.expect(item.logId).to.be.a('string');",
                  "    if (item.cardId) pm.expect(item.cardId).to.match(/^CARD-\\d{6}$/);",
                  "    if (item.gateId) pm.expect(item.gateId).to.match(/^GATE-\\d{2}$/);",
                  "    if (item.direction) pm.expect(item.direction).to.be.oneOf(['IN', 'OUT']);",
                  "    if (item.timestamp) pm.expect(item.timestamp).to.match(/^\\d{4}-\\d{2}-\\d{2}T/);",
                  "    if (item.status) pm.expect(item.status).to.be.oneOf(['ALLOWED', 'DENIED']);",
                  "  }",
                  "});"
                ]
              }
            }
          ]
        },
